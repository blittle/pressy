{
  "name": "@pressy-pub/components",
  "version": "0.1.1",
  "description": "Preact UI components for Pressy — Reader, Navigation, Paywall, and MDX content components",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/blittle/pressy.git",
    "directory": "packages/@pressy/components"
  },
  "homepage": "https://github.com/blittle/pressy#readme",
  "bugs": "https://github.com/blittle/pressy/issues",
  "keywords": [
    "pressy",
    "preact",
    "reader",
    "mdx",
    "components",
    "ebook",
    "paginated-reader"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@preact/signals": "^1.2.0",
    "preact": "^10.19.0",
    "idb-keyval": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@pressy-pub/typography": "workspace:*"
  }
}
